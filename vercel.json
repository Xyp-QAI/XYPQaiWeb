{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/favicon.ico", "destination": "/favicon.png", "permanent": false }
  ],
  "rewrites": [
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/contact.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
