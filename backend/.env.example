# Google Sheets Configuration
# ----------------------------

# The ID of your Google Sheet (from the URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit)
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Google Service Account credentials (JSON key file)
# Option 1: Path to the JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account-key.json

# Option 2: Paste the entire JSON key as a single-line string (for deployment)
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"..."}

# Server port
PORT=3001

# Resend Email Notifications
# ----------------------------
# Sign up at https://resend.dev (free tier = 100 emails/day)
# Get your API key from the Resend dashboard
RESEND_API_KEY=re_xxxxxxxxxxxx

# Admin email(s) to receive contact form notifications
# Single: ADMIN_EMAIL=admin@example.com
# Multiple: ADMIN_EMAILS=admin1@example.com,admin2@example.com
# Or comma-separated in ADMIN_EMAIL: admin1@example.com,admin2@example.com
ADMIN_EMAIL=your-admin@example.com
