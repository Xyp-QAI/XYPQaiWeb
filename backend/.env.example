# Google Sheets Configuration
# ----------------------------

# The ID of your Google Sheet (from the URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit)
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Google Service Account credentials (JSON key file)
# Option 1: Path to the JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account-key.json

# Option 2: Paste the entire JSON key as a single-line string (for deployment)
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"..."}

# Server port
PORT=3001
